{
  "name": "macros",
  "version": "1.0.0",
  "description": "define modifications to a page",
  "main": "background.js",
  "scripts": {
    "build": "node ./copy-files.js && npm run build:macros && npm run build:background && npm run build:content-script",
    "build-new": "node ./copy-files-new.js && npm run build:macros && npm run build:background-new && npm run build:content-script-new",
    "build:macros": "npx webpack --config ./webpack.config.macros.js",
    "build:background": "npx webpack --config ./webpack.config.background.js",
    "build:content-script": "npx webpack --config ./webpack.config.content-script.js",
    "build:background-new": "npx webpack --config ./webpack.config.background-new.js",
    "build:content-script-new": "npx webpack --config ./webpack.config.content-script-new.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emilefokkema/macros.git"
  },
  "keywords": [
    "chrome",
    "extension",
    "macro"
  ],
  "author": "Emile Fokkema",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/emilefokkema/macros/issues"
  },
  "homepage": "https://github.com/emilefokkema/macros#readme",
  "devDependencies": {
    "webpack": "^5.11.0",
    "webpack-cli": "^4.2.0"
  }
}
